# ===== Python cache / bytecode =====
__pycache__/
*.py[cod]
*$py.class

# ===== Virtual environments =====
.venv/
venv/
env/
ENV/

# ===== Build / packaging artifacts =====
build/
dist/
*.spec
*.egg-info/
.eggs/
pip-wheel-metadata/

# ===== Logs / temp =====
*.log
*.tmp
*.temp

# ===== Testing / coverage =====
.pytest_cache/
.coverage
.coverage.*
htmlcov/

# ===== Type checker / linter cache =====
.mypy_cache/
.ruff_cache/
.pyre/

# ===== Jupyter =====
.ipynb_checkpoints/

# ===== IDE / editor =====
.idea/
.vscode/
*.code-workspace

# ===== OS files =====
.DS_Store
Thumbs.db
desktop.ini

